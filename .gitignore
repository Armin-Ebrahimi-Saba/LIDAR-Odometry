# Data and Bags
bags/*
!bags/.gitkeep
data/
*.db3
*.bag
*.bag.bak

# Outputs and Results
output/
results/
maps/
*.pcd

# Unused configurations
config/

# Ignore all scripts except those required for LIO-SAM execution
scripts/*
!scripts/run_lio_sam.sh
!scripts/run_lio_sam_gnss.sh
!scripts/patch_yaml.py
!scripts/format_slam_output.py

# Python environments / cache
__pycache__/
*.pyc
.env
venv/

# Ignore Original Read-Copies
src/LIO-SAM-6AXIS-src/*

# Plotting tools and generated images
plot_tools/
!src/LIO-SAM-6AXIS-src/mapOptmizationGps.cpp
